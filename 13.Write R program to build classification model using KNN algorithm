# Install and load class package (if not already installed)
# install.packages("class")
library(class)

# Create dataset
data <- data.frame(
  StudyHours = c(1, 2, 3, 4, 5, 6, 7, 8),
  Marks = c(35, 40, 50, 55, 65, 70, 80, 85),
  Result = factor(c("Fail", "Fail", "Fail", "Pass", "Pass", "Pass", "Pass", "Pass"))
)

# Split features and target
features <- data[, c("StudyHours", "Marks")]
target <- data$Result

# Normalize features
features_scaled <- scale(features)

# Split into training and test data
train_index <- 1:6
test_index <- 7:8

train_data <- features_scaled[train_index, ]
test_data <- features_scaled[test_index, ]

train_labels <- target[train_index]
test_labels <- target[test_index]

# Apply KNN (k = 3)
predicted <- knn(train = train_data,
                 test = test_data,
                 cl = train_labels,
                 k = 3)

# Results
print("Predicted Class:")
print(predicted)

print("Actual Class:")
print(test_labels)

# Confusion Matrix
print("Confusion Matrix:")
print(table(Predicted = predicted, Actual = test_labels))
