# Load dataset
data(airquality)

# (i) Handle Missing Values
for (col in names(airquality)) {
  
  na_count <- sum(is.na(airquality[[col]]))
  na_percent <- na_count / nrow(airquality)
  
  if (na_count > 0) {
    
    if (na_percent < 0.10) {
      airquality <- airquality[!is.na(airquality[[col]]), ]
    } else {
      if (is.numeric(airquality[[col]])) {
        mean_value <- mean(airquality[[col]], na.rm = TRUE)
        airquality[[col]][is.na(airquality[[col]])] <- mean_value
      }
    }
  }
}

# (ii) Linear Regression using Least Squares
model <- lm(Ozone ~ Solar.R, data = airquality)
print(summary(model))

# (iii) Scatter Plot with Regression Line
plot(airquality$Solar.R, airquality$Ozone,
     main = "Ozone vs Solar.R",
     xlab = "Solar Radiation",
     ylab = "Ozone",
     pch = 16,
     col = "blue")

abline(model, col = "red", lwd = 2)
