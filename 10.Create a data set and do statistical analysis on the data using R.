# Create a dataset
data <- data.frame(
  ID = 1:10,
  Age = c(21, 22, 20, 23, 24, 22, 21, 23, 25, 24),
  Marks = c(78, 85, 69, 90, 88, 76, 95, 89, 84, 91),
  StudyHours = c(2, 3, 1.5, 4, 3.5, 2.5, 5, 4, 3, 4.5)
)

# Display dataset
print(data)

# Structure of dataset
str(data)

# Summary statistics
summary(data)

# Mean, Median, Standard Deviation
mean_marks <- mean(data$Marks)
median_marks <- median(data$Marks)
sd_marks <- sd(data$Marks)

print(mean_marks)
print(median_marks)
print(sd_marks)

# Correlation between Study Hours and Marks
correlation <- cor(data$StudyHours, data$Marks)
print(correlation)

# Linear Regression
model <- lm(Marks ~ StudyHours, data = data)
summary(model)

# Histogram of Marks
hist(data$Marks, main="Histogram of Marks", xlab="Marks", col="lightblue")

# Boxplot of Marks
boxplot(data$Marks, main="Boxplot of Marks", col="lightgreen")
