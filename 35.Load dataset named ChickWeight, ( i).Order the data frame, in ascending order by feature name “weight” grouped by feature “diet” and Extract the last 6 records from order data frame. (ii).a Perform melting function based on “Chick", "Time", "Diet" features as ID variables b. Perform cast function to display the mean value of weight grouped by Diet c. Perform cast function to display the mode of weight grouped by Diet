# Load dataset
data(ChickWeight)

# (i) Order by Diet and Weight (ascending)
ordered_data <- ChickWeight[order(ChickWeight$Diet, ChickWeight$weight), ]

# Extract last 6 records
tail_records <- tail(ordered_data, 6)
print(tail_records)


# Load reshape2 package
# install.packages("reshape2")  # Uncomment if not installed
library(reshape2)

# (ii.a) Melt with Chick, Time, Diet as ID variables
melted_data <- melt(ChickWeight, id.vars = c("Chick", "Time", "Diet"))
print(head(melted_data))

# (ii.b) Cast to display mean weight grouped by Diet
mean_weight <- dcast(melted_data, Diet ~ variable, mean)
print(mean_weight)

# (ii.c) Cast to display mode of weight grouped by Diet
mode_function <- function(x) {
  ux <- unique(x)
  ux[which.max(tabulate(match(x, ux)))]
}

mode_weight <- dcast(melted_data, Diet ~ variable, mode_function)
print(mode_weight)
