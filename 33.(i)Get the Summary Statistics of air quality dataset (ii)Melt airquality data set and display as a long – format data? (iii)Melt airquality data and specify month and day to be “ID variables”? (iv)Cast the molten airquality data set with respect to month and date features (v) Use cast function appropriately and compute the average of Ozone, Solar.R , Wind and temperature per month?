# Load required package
# install.packages("reshape2")   # Uncomment if not installed
library(reshape2)

# Load dataset
data(airquality)

# (i) Summary Statistics
print(summary(airquality))

# (ii) Melt airquality dataset (long format)
melted_data <- melt(airquality)
print(head(melted_data))

# (iii) Melt with Month and Day as ID variables
melted_data_id <- melt(airquality, id.vars = c("Month", "Day"))
print(head(melted_data_id))

# (iv) Cast molten data with respect to Month and Day
cast_data <- dcast(melted_data_id, Month + Day ~ variable)
print(head(cast_data))

# (v) Compute average of Ozone, Solar.R, Wind and Temp per Month
monthly_avg <- dcast(melted_data_id, Month ~ variable, mean, na.rm = TRUE)
print(monthly_avg)
