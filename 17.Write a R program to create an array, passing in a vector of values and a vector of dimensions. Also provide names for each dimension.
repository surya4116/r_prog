# Create a vector of values
values <- 1:12

# Define dimensions (2 x 3 x 2)
dimensions <- c(2, 3, 2)

# Create array with dimension names
my_array <- array(values,
                  dim = dimensions,
                  dimnames = list(
                    Row = c("R1", "R2"),
                    Column = c("C1", "C2", "C3"),
                    Matrix = c("M1", "M2")
                  ))

# Display array
print(my_array)

# Display structure
str(my_array)
